; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Unnamed Pirate FPS"
run/main_scene="res://scenes/world.tscn"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

MunitionsEmitters="*res://scenes/globals/munitions_emitters.tscn"
DropHandler="*res://scenes/drop_handler.tscn"
Drop_Data="*res://scripts/drop_data.gd"
SignalBus="*res://scripts/SignalBus.gd"
CurseManager="*res://scripts/curses/curse_manager.gd"
UnlockedWeapons="*res://scripts/weapons/globals/unlocked_weapons.gd"
CurrentLoadout="*res://scripts/weapons/globals/current_loadout.gd"
GlobalResources="*res://scripts/globals/global_resources.gd"
PlayerStats="*res://scripts/player/player_stats.gd"
Settings="*res://scripts/globals/settings.gd"

[debug]

gdscript/warnings/untyped_declaration=1
gdscript/warnings/inferred_declaration=1
gdscript/warnings/return_value_discarded=1

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
display_server/driver.linuxbsd="x11"

[editor]

movie_writer/movie_file="/home/kompreya/Projects/Game Dev/First Person Tut/Godot/first-person-controller-tut/movies/test.avi"

[file_customization]

folder_colors={
"res://addons/": "blue",
"res://assets/": "yellow",
"res://resources/": "pink",
"res://scenes/": "orange",
"res://scripts/": "green"
}

[global_group]

enemy=""
crate=""
player=""
enemybodypart=""
random_target=""

